# Supabase — create a project at https://supabase.com, run the migration in
# bcgd/supabase/migrations, then copy these from Project Settings → API.
# Restart the dev server after editing. Copy this file to `.env`.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
